import requests
import pandas as pd

# =========================
# PEGAR TOP 200 MOEDAS
# =========================

def get_top_coins():

    url = "https://api.coingecko.com/api/v3/coins/markets"

    params = {
        "vs_currency": "usd",
        "order": "volume_desc",
        "per_page": 200,
        "page": 1,
        "sparkline": "false"
    }

    try:

        r = requests.get(url, params=params, timeout=10)

        data = r.json()

        if not isinstance(data, list):
            print("Erro CoinGecko:", data)
            return []

        return data

    except Exception as e:

        print("Erro API:", e)

        return []

# =========================
# INDICADORES
# =========================

def ema(data, period):

    return data.ewm(span=period, adjust=False).mean()


def calculate_rsi(data, period=14):

    delta = data.diff()

    gain = delta.clip(lower=0)
    loss = -1 * delta.clip(upper=0)

    avg_gain = gain.rolling(period).mean()
    avg_loss = loss.rolling(period).mean()

    rs = avg_gain / avg_loss

    rsi = 100 - (100 / (1 + rs))

    return rsi


# =========================
# OHLC
# =========================

def get_ohlc(coin):

    url = f"https://api.coingecko.com/api/v3/coins/{coin}/ohlc"

    params = {
        "vs_currency": "usd",
        "days": 1
    }

    try:

        r = requests.get(url, params=params, timeout=10)

        data = r.json()

        if not isinstance(data, list):
            return None

        df = pd.DataFrame(data, columns=[
            "time",
            "open",
            "high",
            "low",
            "close"
        ])

        return df

    except:

        return None


# =========================
# ANALISE TECNICA
# =========================

def analyze_coin(coin):

    df = get_ohlc(coin)

    if df is None or len(df) < 50:
        return None

    close = df["close"]

    df["EMA20"] = ema(close, 20)
    df["EMA50"] = ema(close, 50)

    df["RSI"] = calculate_rsi(close)

    last = df.iloc[-1]

    price = last["close"]
    ema20 = last["EMA20"]
    ema50 = last["EMA50"]
    rsi = last["RSI"]

    score = 0

    if ema20 > ema50:
        score += 2

    if price <= ema20 * 1.01:
        score += 2

    if rsi < 45:
        score += 2

    confidence = score * 15

    if confidence >= 60:

        entry = price
        target = price * 1.06
        stop = price * 0.97

        return {
            "asset": coin.upper(),
            "entry": round(entry, 4),
            "target": round(target, 4),
            "stop": round(stop, 4),
            "confidence": confidence
        }

    return None


# =========================
# RADAR PRINCIPAL
# =========================

def run_radar():

    print("📡 ZAPID AI MARKET SCANNER")

    coins = get_top_coins()

    if not coins:
        return []

    candidates = []

    for coin in coins:

        change = coin.get("price_change_percentage_24h")

        if change and abs(change) > 3:

            candidates.append(coin["id"])

    candidates = candidates[:20]

    opportunities = []

    for coin in candidates:

        trade = analyze_coin(coin)

        if trade:
            opportunities.append(trade)

    opportunities.sort(key=lambda x: x["confidence"], reverse=True)

    return opportunities[:5]

